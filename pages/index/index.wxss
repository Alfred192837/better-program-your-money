/* Manage button in header */
.manage-btn {
  font-size: 26rpx;
  color: var(--primary);
  padding: 4rpx 8rpx;
}

/* Monthly overview card */
.overview-card {
  padding: 32rpx 24rpx;
}

.overview-header {
  font-size: 26rpx;
  color: var(--text-secondary);
  margin-bottom: 24rpx;
}

.overview-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-around;
}

.overview-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.overview-label {
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-bottom: 8rpx;
}

.overview-value {
  font-size: 36rpx;
  font-weight: 700;
}

.overview-divider {
  width: 2rpx;
  height: 48rpx;
  background-color: var(--border);
}

/* Bill list */
.bill-scroll {
  height: calc(100vh - 280rpx);
}

.bill-item {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 24rpx;
}

.bill-left {
  display: flex;
  flex-direction: column;
  flex: 1;
}

.bill-category {
  font-size: 30rpx;
  font-weight: 500;
  color: var(--text-primary);
  margin-bottom: 6rpx;
}

.bill-note {
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-bottom: 4rpx;
}

.bill-date {
  font-size: 22rpx;
  color: var(--text-secondary);
}

.bill-right {
  margin-left: 20rpx;
}

.bill-amount {
  font-size: 34rpx;
  font-weight: 600;
}

.income {
  color: var(--income);
}

.expense {
  color: var(--expense);
}

/* Load more */
.load-more-tip {
  text-align: center;
  padding: 30rpx;
  color: var(--text-secondary);
  font-size: 24rpx;
}

/* Checkbox */
.checkbox {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  border: 3rpx solid var(--border);
  margin-right: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  font-size: 24rpx;
  color: #fff;
}

.checkbox-checked {
  background-color: var(--primary);
  border-color: var(--primary);
}

.bill-scroll-select {
  height: calc(100vh - 370rpx);
}

/* FAB */
.fab {
  position: fixed;
  right: 40rpx;
  bottom: 120rpx;
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background-color: var(--primary);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(7, 193, 96, 0.4);
  z-index: 99;
}

.fab-icon {
  font-size: 56rpx;
  color: #fff;
  line-height: 1;
}

/* Batch delete bar */
.batch-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 100rpx;
  background: var(--card);
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  padding: 0 32rpx;
  border-top: 2rpx solid var(--border);
  z-index: 100;
}

.batch-count {
  font-size: 28rpx;
  color: var(--text-primary);
}

.batch-cancel {
  padding: 14rpx 28rpx;
  font-size: 26rpx;
}

.batch-delete {
  padding: 14rpx 28rpx;
  font-size: 26rpx;
}

.btn-danger {
  background-color: var(--expense);
  color: #fff;
  border-radius: 8rpx;
}

.btn-disabled {
  opacity: 0.4;
  pointer-events: none;
}
